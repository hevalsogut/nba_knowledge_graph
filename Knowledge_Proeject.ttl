#################################################################

###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/belongsTo
:belongsTo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Team ;
           rdfs:range :Conference .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/coaches
:coaches rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdfs:domain :Coach ;
         rdfs:range :Team .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasHomeArena
:hasHomeArena rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain :Team ;
              rdfs:range :Arena .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasPlayer
:hasPlayer rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           owl:inverseOf :playsFor .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasRival
:hasRival rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdf:type owl:SymmetricProperty ;
          rdfs:domain :Team ;
          rdfs:range :Team .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/isDraftedBy
:isDraftedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/playPosition
:playPosition rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Player ;
              rdfs:range :Position .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/playsFor
:playsFor rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdfs:domain :Player ;
          rdfs:range :Team .


