@prefix : <http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10#> .
@prefix nba: <http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10#> .

<http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/belongsTo
nba:belongsTo rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain nba:Team ;
              rdfs:range nba:Conference .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/coaches
nba:coaches rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain nba:Coach ;
            rdfs:range nba:Team .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasHomeArena
nba:hasHomeArena rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain nba:Team ;
                 rdfs:range nba:Arena .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasPlayer
nba:hasPlayer rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              owl:inverseOf nba:playsFor .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasRival
nba:hasRival rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdf:type owl:SymmetricProperty ;
             rdfs:domain nba:Team ;
             rdfs:range nba:Team .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/isDraftedBy
nba:isDraftedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/playPosition
nba:playPosition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain nba:Player ;
                 rdfs:range nba:Position .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/playsFor
nba:playsFor rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain nba:Player ;
             rdfs:range nba:Team .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/attendance
nba:attendance rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf nba:hasCapacity .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/championshipsWon
nba:championshipsWon rdf:type owl:DatatypeProperty ;
                     rdfs:domain nba:Team ;
                     rdfs:range xsd:int ;
                     rdfs:label "Championship number" .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasCapacity
nba:hasCapacity rdf:type owl:DatatypeProperty ;
                rdfs:domain nba:Arena ;
                rdfs:range xsd:int ;
                rdfs:label "Capacity of the arena" .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasHeight
nba:hasHeight rdf:type owl:DatatypeProperty ;
              rdfs:domain nba:Player ;
              rdfs:range xsd:double ;
              rdfs:label "player height" .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/hasJerseyNumber
nba:hasJerseyNumber rdf:type owl:DatatypeProperty ;
                    rdfs:domain nba:Player ;
                    rdfs:range xsd:int ;
                    rdfs:label "jersey number" .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/playerName
nba:playerName rdf:type owl:DatatypeProperty ;
               rdfs:domain nba:Player ;
               rdfs:range xsd:string ;
               rdfs:label "player name" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Arena
nba:Arena rdf:type owl:Class ;
          rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Center
nba:Center rdf:type owl:Class ;
           rdfs:subClassOf nba:Position .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Coach
nba:Coach rdf:type owl:Class ;
          rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Conference
nba:Conference rdf:type owl:Class ;
               rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/EasternConferance
nba:EasternConferance rdf:type owl:Class ;
                      rdfs:subClassOf nba:Conference .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/EasternConferenceTeam
nba:EasternConferenceTeam rdf:type owl:Class ;
                          rdfs:subClassOf nba:Team .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Forward
nba:Forward rdf:type owl:Class ;
            rdfs:subClassOf nba:Position .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Game
nba:Game rdf:type owl:Class ;
         rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Guard
nba:Guard rdf:type owl:Class ;
          rdfs:subClassOf nba:Position .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/NBA-Member
nba:NBA-Member rdf:type owl:Class .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Player
nba:Player rdf:type owl:Class ;
           rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Position
nba:Position rdf:type owl:Class ;
             rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/Team
nba:Team rdf:type owl:Class ;
         rdfs:subClassOf nba:NBA-Member .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/WesternConferance
nba:WesternConferance rdf:type owl:Class ;
                      rdfs:subClassOf nba:Conference .


###  http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/WesternConferenceTeam
nba:WesternConferenceTeam rdf:type owl:Class ;
                          rdfs:subClassOf nba:Team .


