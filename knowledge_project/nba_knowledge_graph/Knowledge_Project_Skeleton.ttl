nba:hasCapacity a owl:DatatypeProperty ;
    rdfs:label "Capacity of the arena" ;
    rdfs:domain nba:Arena ;
    rdfs:range xsd:int .

nba:playsFor a owl:ObjectProperty ;
    rdfs:domain nba:Player ;
    rdfs:range nba:Team ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:Conference a owl:Class ;
    rdfs:subClassOf nba:NBA-Member .

nba:Position a owl:Class ;
    rdfs:subClassOf nba:NBA-Member .

nba:NBA-Member a owl:Class .

nba:Player a owl:Class ;
    rdfs:subClassOf nba:NBA-Member .

owl:topObjectProperty rdfs:domain nba:Player ;
    rdfs:range nba:Team .

nba:Arena a owl:Class ;
    rdfs:subClassOf nba:NBA-Member .

