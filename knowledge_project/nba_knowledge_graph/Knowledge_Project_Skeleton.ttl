nba:WesternConferance a owl:Class ;
    rdfs:subClassOf nba:Conference .

nba:WesternConferenceTeam a owl:Class ;
    rdfs:subClassOf nba:Team .

nba:attendance a owl:DatatypeProperty ;
    rdfs:subPropertyOf nba:hasCapacity .

nba:belongsTo a owl:ObjectProperty ;
    rdfs:domain nba:Team ;
    rdfs:range nba:Conference ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:championshipsWon a owl:DatatypeProperty ;
    rdfs:label "Championship number" ;
    rdfs:domain nba:Team ;
    rdfs:range xsd:int .

nba:coaches a owl:ObjectProperty ;
    rdfs:domain nba:Coach ;
    rdfs:range nba:Team ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:hasHeight a owl:DatatypeProperty ;
    rdfs:label "player height" ;
    rdfs:domain nba:Player ;
    rdfs:range xsd:double .

nba:hasHomeArena a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain nba:Team ;
    rdfs:range nba:Arena ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:hasJerseyNumber a owl:DatatypeProperty ;
    rdfs:label "jersey number" ;
    rdfs:domain nba:Player ;
    rdfs:range xsd:int .

nba:hasPlayer a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:inverseOf nba:playsFor .

nba:hasRival a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain nba:Team ;
    rdfs:range nba:Team ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:isDraftedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:playPosition a owl:ObjectProperty ;
    rdfs:domain nba:Player ;
    rdfs:range nba:Position ;
    rdfs:subPropertyOf owl:topObjectProperty .

nba:playerName a owl:DatatypeProperty ;
    rdfs:label "player name" ;
    rdfs:domain nba:Player ;
    rdfs:range xsd:string .

nba:Atlanta_Hawks_Arena a nba:Arena .

