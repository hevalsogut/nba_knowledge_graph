@prefix nba: <http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/veliu/ontologies/2026/3/untitled-ontology-10> a owl:Ontology .

nba:Atlanta_Hawks a nba:Team,
        owl:NamedIndividual ;
    nba:hasHomeArena nba:Atlanta_Hawks_Arena ;
    nba:playerName "Atlanta Hawks" .

